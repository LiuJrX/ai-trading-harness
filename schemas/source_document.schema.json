{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-trading-harness.local/schemas/source_document.schema.json",
  "title": "SourceDocument",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "source_type",
    "created_at",
    "status",
    "content_ref"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:-]*$"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "historical_image_note",
        "human_strategy_note",
        "daily_trade_review",
        "trade_record",
        "market_snapshot",
        "agent_strategy_proposal",
        "screenshot",
        "manual_note"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trade_date": {
      "type": "string",
      "format": "date"
    },
    "date_range": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "string",
          "format": "date"
        },
        "end": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "content_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file_path",
            "inline_text",
            "external_ref"
          ]
        },
        "value": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "image_width": {
          "type": "integer",
          "minimum": 1
        },
        "image_height": {
          "type": "integer",
          "minimum": 1
        },
        "author": {
          "type": "string"
        },
        "software": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending_extraction",
        "extracted",
        "reviewed",
        "archived",
        "rejected"
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewed_by": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
